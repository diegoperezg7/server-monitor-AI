# CrowdSec credentials - Get these from your CrowdSec installation
# Run: cscli machines add dashboard-monitor --password YOUR_PASSWORD
CROWDSEC_MACHINE_ID=dashboard-monitor
CROWDSEC_PASSWORD=your_crowdsec_password_here

# CrowdSec bouncer key - Get from: cscli bouncers add monitor-bouncer
CROWDSEC_BOUNCER_KEY=your_bouncer_key_here

# Telegram Alerts - Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Healthchecks.io - Create a check at https://healthchecks.io and paste the ping URL here
HEALTHCHECK_PING_URL=

# Dashboard URL (included in alert messages)
DASHBOARD_URL=https://monitor.yourdomain.com

# Dashboard password (SHA1 hash of your password, leave empty to disable auth)
# Generate with: echo -n "yourpassword" | sha1sum | cut -d' ' -f1
DASHBOARD_PASSWORD=
